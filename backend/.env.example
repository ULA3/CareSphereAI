# ─── CareSphere AI — Backend Environment ──────────────────────────────────────
# Copy this file to .env and fill in real values.

# ─── Core ─────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─── Google Gemini (required) ────────────────────────────────────────────────
# Get your key: https://aistudio.google.com/apikey
GOOGLE_GENAI_API_KEY=

# ─── Twilio SMS (optional — for real caregiver alerts) ───────────────────────
# Sign up free trial: https://www.twilio.com/try-twilio
# You get $15 trial credit + a free Twilio phone number.
# After signup, grab these from https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=          # Twilio-registered sender, E.164 format (e.g. +14155551234)

# ─── SendGrid Email (optional — for real caregiver alerts) ───────────────────
# Sign up free: https://signup.sendgrid.com (100 emails/day free forever)
# Create API key: https://app.sendgrid.com/settings/api_keys
# Verify sender email: https://app.sendgrid.com/settings/sender_auth
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=         # Verified sender email (e.g. alerts@caresphere.ai)

# ─── Demo Overrides (optional) ───────────────────────────────────────────────
# Override every patient's caregiver phone/email with YOUR contact for demo day.
# Unset in production — real caregiver contacts will be used.
ALERT_DEMO_PHONE=            # e.g. +60123456789 (your phone)
ALERT_DEMO_EMAIL=            # e.g. you@gmail.com
